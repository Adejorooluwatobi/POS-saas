{
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "RetailOS_Api",
    "Audience": "RetailOS_Clients",
    "ExpirationInMinutes": 1440
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
