{
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "RetailOS_Api",
    "Audience": "RetailOS_Clients",
    "ExpirationInMinutes": 1440
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SuperAdmin": {
    "Email": "${SUPERADMIN_EMAIL}",
    "Password": "${SUPERADMIN_PASSWORD}"
  },
  "Email": {
    "SmtpHost": "smtp.mailtrap.io",
    "SmtpPort": 587,
    "SmtpUser": "",
    "SmtpPass": "",
    "FromEmail": "noreply@retailos.io",
    "FromName": "RetailOS Notifications"
  }
}
